CREATE DATABASE IF NOT EXISTS foundry_demo;
USE foundry_demo;

CREATE TABLE pipeline_runs (
run_id STRING,
job_name STRING,
git_commit STRING,
branch STRING,
start_time TIMESTAMP,
end_time TIMESTAMP,
status STRING
);

CREATE TABLE dataset_versions (
table_name STRING,
version BIGINT,
run_id STRING,
created_at TIMESTAMP
);

CREATE TABLE lineage_edges (
output_table STRING,
input_table STRING,
input_version BIGINT,
run_id STRING
);


CREATE TABLE data_quality_results (
run_id STRING,
table_name STRING,
check_name STRING,
status STRING,
checked_at TIMESTAMP
);


CREATE OR REPLACE TABLE bronze_orders (
order_id INT,
customer_id INT,
amount DOUBLE,
status STRING
);

